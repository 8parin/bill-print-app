# Neon PostgreSQL Database URL
# Get this from your Neon dashboard: https://console.neon.tech
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://username:password@host.neon.tech/billprint

# Flask configuration
FLASK_ENV=production
FLASK_DEBUG=0

# App password protection (set in Render dashboard)
APP_PASSWORD=your-password-here
SECRET_KEY=your-random-secret-key-here

# Output directory for generated bills
OUTPUT_DIR=output/bills